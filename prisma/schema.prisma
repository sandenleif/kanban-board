generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  CREATED
  UPDATED
  MOVED
  ASSIGNED
  COMMENTED
  COMPLETED
  REOPENED
  LABEL_ADDED
  LABEL_REMOVED
  DUE_DATE_SET
  DUE_DATE_REMOVED
  CHECKLIST_UPDATED
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum ChecklistItemPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  status    OrgStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users          User[]
  workspaces     Workspace[]
  settings       AppSettings?
  ticketQueues      TicketQueue[]
  ticketTeams       TicketTeam[]
  ticketCategories  TicketCategory[]
  ticketContacts    TicketContact[]
  portalUsers       PortalUser[]
  tickets           Ticket[]
  exchangeConfig    ExchangeConfig?
  ldapConfig        LdapConfig?

  @@map("organizations")
}

model AppSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  logoBase64     String?  @db.Text
  logoMimeType   String?
  locale         String   @default("en")
  siteTitle      String?
  smtpHost       String?
  smtpPort       Int?
  smtpUser       String?
  smtpPassword   String?
  smtpFrom       String?
  smtpSecure     Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("app_settings")
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  name           String
  password       String?
  avatarUrl      String?
  avatarBase64   String?    @db.Text
  avatarMimeType String?
  status         UserStatus @default(PENDING)
  isAdmin        Boolean    @default(false)
  isSuperAdmin   Boolean    @default(false)
  theme          String     @default("dark")
  organizationId String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization        Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  workspaceMembers    WorkspaceMember[]
  ownedWorkspaces     Workspace[]          @relation("WorkspaceOwner")
  createdProjects     Project[]            @relation("ProjectCreator")
  assignedTasks       TaskAssignee[]
  createdTasks        Task[]               @relation("TaskCreator")
  comments            TaskComment[]
  activities          TaskActivity[]
  uploads             Attachment[]
  notifications       Notification[]
  personalSpace       PersonalSpace?
  passwordResetTokens PasswordResetToken[]
  createdTickets      Ticket[]             @relation("TicketCreator")
  assignedTickets     Ticket[]             @relation("TicketAssignee")
  lockedTickets       Ticket[]             @relation("TicketLocker")
  ticketComments      TicketComment[]

  @@map("users")
}

model Workspace {
  id             String   @id @default(cuid())
  name           String
  description    String?
  slug           String   @unique
  ownerId        String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner               User                       @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members             WorkspaceMember[]
  projects            Project[]
  checklistCategories WorkspaceChecklistCategory[]
  notes               WorkspaceNote[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  workspaceId String
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User             @relation("ProjectCreator", fields: [createdById], references: [id])
  sections  ProjectSection[]
  labels    TaskLabel[]

  @@map("projects")
}

model ProjectSection {
  id        String   @id @default(cuid())
  name      String
  position  Int
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns BoardColumn[]

  @@map("project_sections")
}

model BoardColumn {
  id        String   @id @default(cuid())
  name      String
  position  Int
  sectionId String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section ProjectSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("board_columns")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  position    Int
  columnId    String
  projectId   String
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  column        BoardColumn         @relation(fields: [columnId], references: [id], onDelete: Cascade)
  createdBy     User                @relation("TaskCreator", fields: [createdById], references: [id])
  assignees     TaskAssignee[]
  labels        TaskLabelOnTask[]
  comments      TaskComment[]
  checklist     TaskChecklistItem[]
  activities    TaskActivity[]
  attachments   Attachment[]
  notifications Notification[]

  @@map("tasks")
}

model TaskAssignee {
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("task_assignees")
}

model TaskLabel {
  id        String @id @default(cuid())
  name      String
  color     String
  projectId String

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   TaskLabelOnTask[]

  @@map("task_labels")
}

model TaskLabelOnTask {
  taskId  String
  labelId String

  task  Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@map("task_label_on_task")
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@map("task_comments")
}

model TaskChecklistItem {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  position  Int
  taskId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_checklist_items")
}

model TaskActivity {
  id        String       @id @default(cuid())
  type      ActivityType
  content   String?
  taskId    String
  userId    String
  createdAt DateTime     @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("task_activities")
}

model Attachment {
  id           String   @id @default(cuid())
  name         String
  url          String
  fileData     String?  @db.Text
  size         Int
  mimeType     String
  taskId       String
  uploadedById String
  createdAt    DateTime @default(now())

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@map("attachments")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  message     String
  taskId      String?
  taskTitle   String?
  projectId   String?
  workspaceId String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@map("notifications")
}

// ── Ticket System (full-setup only) ───────────────────────────────────────

model TicketQueue {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets      Ticket[]

  @@map("ticket_queues")
}

model TicketTeam {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  position       Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets      Ticket[]

  @@map("ticket_teams")
}

model TicketCategory {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  position       Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets      Ticket[]

  @@map("ticket_categories")
}

model Ticket {
  id             String         @id @default(cuid())
  number         Int            @default(autoincrement())
  title          String
  description    String?        @db.Text
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  organizationId String
  queueId        String?
  createdById    String
  assignedToId   String?
  linkedTaskId   String?
  emailMessageId String?
  fromEmail      String?
  fromName       String?
  teamId          String?
  categoryId      String?
  contactId       String?
  topic           String?
  inventoryNumber String?
  requesterType   String  @default("customer")
  locked          Boolean        @default(false)
  lockedById      String?
  lockedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  closedAt        DateTime?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  queue        TicketQueue?    @relation(fields: [queueId], references: [id], onDelete: SetNull)
  team         TicketTeam?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  category     TicketCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  contact      TicketContact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdBy    User            @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo   User?           @relation("TicketAssignee", fields: [assignedToId], references: [id])
  lockedBy     User?           @relation("TicketLocker", fields: [lockedById], references: [id])
  comments     TicketComment[]

  @@index([organizationId, status])
  @@index([organizationId, topic])
  @@index([organizationId, inventoryNumber])
  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String
  content    String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@map("ticket_comments")
}

model ExchangeConfig {
  id             String    @id @default(cuid())
  organizationId String    @unique
  host           String
  port           Int       @default(993)
  username       String
  password       String
  mailbox        String    @default("INBOX")
  useSSL         Boolean   @default(true)
  enabled        Boolean   @default(false)
  lastCheckedAt  DateTime?
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("exchange_configs")
}

model LdapConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  host           String
  port           Int      @default(389)
  bindDn         String
  bindPassword   String
  baseDn         String
  loginBaseDn    String?
  userFilter     String   @default("(objectClass=person)")
  enabled        Boolean  @default(false)
  lastSyncAt     DateTime?
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("ldap_configs")
}

model TicketContact {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  company        String?
  department     String?
  externalId     String?
  source         String   @default("manual")
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets      Ticket[]
  portalUsers  PortalUser[]

  @@unique([organizationId, email])
  @@index([organizationId, source])
  @@map("ticket_contacts")
}

model PortalUser {
  id             String   @id @default(cuid())
  organizationId String
  contactId      String?
  name           String
  email          String
  passwordHash   String?
  ldapUsername   String?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      TicketContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([organizationId, email])
  @@map("portal_users")
}

// ── Password Reset ─────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ── Workspace Checklist ────────────────────────────────────────────────────

model WorkspaceChecklistCategory {
  id          String                   @id @default(cuid())
  name        String
  position    Int                      @default(0)
  workspaceId String
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  workspace Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items     WorkspaceChecklistItem[]

  @@map("workspace_checklist_categories")
}

model WorkspaceChecklistItem {
  id         String                @id @default(cuid())
  title      String
  priority   ChecklistItemPriority @default(MEDIUM)
  position   Int                   @default(0)
  categoryId String
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  category WorkspaceChecklistCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subItems WorkspaceChecklistSubItem[]

  @@map("workspace_checklist_items")
}

model WorkspaceChecklistSubItem {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  completed   Boolean  @default(false)
  position    Int      @default(0)
  itemId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  item WorkspaceChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("workspace_checklist_sub_items")
}

// ── Notes ─────────────────────────────────────────────────────────────────

enum NotePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model WorkspaceNote {
  id          String       @id @default(cuid())
  workspaceId String
  title       String       @default("Notiz")
  content     String?      @db.Text
  priority    NotePriority @default(MEDIUM)
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_notes")
}

model PersonalNote {
  id              String       @id @default(cuid())
  personalSpaceId String
  title           String       @default("Notiz")
  content         String?      @db.Text
  priority        NotePriority @default(MEDIUM)
  position        Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  personalSpace PersonalSpace @relation(fields: [personalSpaceId], references: [id], onDelete: Cascade)

  @@map("personal_notes")
}

// ── Personal Space ─────────────────────────────────────────────────────────

model PersonalSpace {
  id        String   @id @default(cuid())
  userId    String   @unique
  updatedAt DateTime @updatedAt

  user                        User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalChecklistCategories PersonalChecklistCategory[]
  personalNotes               PersonalNote[]

  @@map("personal_spaces")
}

model PersonalChecklistCategory {
  id              String                  @id @default(cuid())
  name            String
  position        Int                     @default(0)
  personalSpaceId String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  personalSpace PersonalSpace           @relation(fields: [personalSpaceId], references: [id], onDelete: Cascade)
  items         PersonalChecklistItem[]

  @@map("personal_checklist_categories")
}

model PersonalChecklistItem {
  id         String                @id @default(cuid())
  title      String
  priority   ChecklistItemPriority @default(MEDIUM)
  position   Int                   @default(0)
  categoryId String
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  category PersonalChecklistCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subItems PersonalChecklistSubItem[]

  @@map("personal_checklist_items")
}

model PersonalChecklistSubItem {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  completed   Boolean  @default(false)
  position    Int      @default(0)
  itemId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  item PersonalChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("personal_checklist_sub_items")
}
