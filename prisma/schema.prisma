generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  CREATED
  UPDATED
  MOVED
  ASSIGNED
  COMMENTED
  COMPLETED
  REOPENED
  LABEL_ADDED
  LABEL_REMOVED
  DUE_DATE_SET
  DUE_DATE_REMOVED
  CHECKLIST_UPDATED
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum ChecklistItemPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  status    OrgStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users          User[]
  workspaces     Workspace[]
  settings       AppSettings?
  ticketQueues      TicketQueue[]
  ticketTeams       TicketTeam[]
  ticketCategories  TicketCategory[]
  ticketContacts    TicketContact[]
  portalUsers       PortalUser[]
  tickets           Ticket[]
  exchangeConfig    ExchangeConfig?
  ldapConfig        LdapConfig?
  assetCategories   AssetCategory[]
  assetLocations    AssetLocation[]
  assets            Asset[]
  softwarePackages  SoftwarePackage[]
  softwareAgents    SoftwareAgent[]
  agentGroups       AgentGroup[]
  networkVlans      NetworkVlan[]

  @@map("organizations")
}

model AppSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  logoBase64     String?  @db.Text  // legacy — kept for migration
  logoMimeType   String?
  logoPath       String?            // filesystem path (preferred)
  locale         String   @default("en")
  siteTitle      String?
  smtpHost        String?
  smtpPort        Int?
  smtpUser        String?
  smtpPassword    String?
  smtpFrom        String?
  smtpSecure      Boolean  @default(false)
  enrollmentToken String?  // shared secret for PC auto-registration
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("app_settings")
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  name           String
  password       String?
  avatarUrl      String?
  avatarBase64   String?    @db.Text  // legacy — kept for migration
  avatarMimeType String?
  avatarPath     String?              // filesystem path (preferred)
  status         UserStatus @default(PENDING)
  isAdmin        Boolean    @default(false)
  isSuperAdmin   Boolean    @default(false)
  theme          String     @default("dark")
  organizationId String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization        Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  workspaceMembers    WorkspaceMember[]
  ownedWorkspaces     Workspace[]          @relation("WorkspaceOwner")
  createdProjects     Project[]            @relation("ProjectCreator")
  assignedTasks       TaskAssignee[]
  createdTasks        Task[]               @relation("TaskCreator")
  comments            TaskComment[]
  activities          TaskActivity[]
  uploads             Attachment[]
  notifications       Notification[]
  personalSpace       PersonalSpace?
  passwordResetTokens PasswordResetToken[]
  createdTickets      Ticket[]             @relation("TicketCreator")
  assignedTickets     Ticket[]             @relation("TicketAssignee")
  lockedTickets       Ticket[]             @relation("TicketLocker")
  ticketComments      TicketComment[]
  assignedAssets      Asset[]              @relation("AssetAssignee")
  assetAssignments    AssetAssignment[]    @relation("AssetAssignmentUser")

  @@map("users")
}

model Workspace {
  id             String   @id @default(cuid())
  name           String
  description    String?
  slug           String   @unique
  ownerId        String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner               User                       @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members             WorkspaceMember[]
  projects            Project[]
  checklistCategories WorkspaceChecklistCategory[]
  notes               WorkspaceNote[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  workspaceId String
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User             @relation("ProjectCreator", fields: [createdById], references: [id])
  sections  ProjectSection[]
  labels    TaskLabel[]

  @@map("projects")
}

model ProjectSection {
  id        String   @id @default(cuid())
  name      String
  position  Int
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns BoardColumn[]

  @@map("project_sections")
}

model BoardColumn {
  id        String   @id @default(cuid())
  name      String
  position  Int
  sectionId String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section ProjectSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("board_columns")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  position    Int
  columnId    String
  projectId   String
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  column        BoardColumn         @relation(fields: [columnId], references: [id], onDelete: Cascade)
  createdBy     User                @relation("TaskCreator", fields: [createdById], references: [id])
  assignees     TaskAssignee[]
  labels        TaskLabelOnTask[]
  comments      TaskComment[]
  checklist     TaskChecklistItem[]
  activities    TaskActivity[]
  attachments   Attachment[]
  notifications Notification[]

  @@map("tasks")
}

model TaskAssignee {
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

model TaskLabel {
  id        String @id @default(cuid())
  name      String
  color     String
  projectId String

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   TaskLabelOnTask[]

  @@map("task_labels")
}

model TaskLabelOnTask {
  taskId  String
  labelId String

  task  Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@map("task_label_on_task")
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([taskId])
  @@map("task_comments")
}

model TaskChecklistItem {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  position  Int
  taskId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_checklist_items")
}

model TaskActivity {
  id        String       @id @default(cuid())
  type      ActivityType
  content   String?
  taskId    String
  userId    String
  createdAt DateTime     @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
  @@map("task_activities")
}

model Attachment {
  id           String   @id @default(cuid())
  name         String
  url          String
  fileData     String?  @db.Text
  size         Int
  mimeType     String
  taskId       String
  uploadedById String
  createdAt    DateTime @default(now())

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@map("attachments")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  message     String
  taskId      String?
  taskTitle   String?
  projectId   String?
  workspaceId String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@map("notifications")
}

// ── Ticket System (full-setup only) ───────────────────────────────────────

model TicketQueue {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets      Ticket[]

  @@map("ticket_queues")
}

model TicketTeam {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  position       Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets      Ticket[]

  @@map("ticket_teams")
}

model TicketCategory {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  position       Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets      Ticket[]

  @@map("ticket_categories")
}

model Ticket {
  id             String         @id @default(cuid())
  number         Int            @default(autoincrement())
  title          String
  description    String?        @db.Text
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  organizationId String
  queueId        String?
  createdById    String
  assignedToId   String?
  linkedTaskId   String?
  emailMessageId String?
  fromEmail      String?
  fromName       String?
  teamId          String?
  categoryId      String?
  contactId       String?
  topic           String?
  inventoryNumber String?
  requesterType   String  @default("customer")
  locked          Boolean        @default(false)
  lockedById      String?
  lockedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  closedAt        DateTime?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  queue        TicketQueue?    @relation(fields: [queueId], references: [id], onDelete: SetNull)
  team         TicketTeam?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  category     TicketCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  contact      TicketContact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdBy    User            @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo   User?           @relation("TicketAssignee", fields: [assignedToId], references: [id])
  lockedBy     User?           @relation("TicketLocker", fields: [lockedById], references: [id])
  comments     TicketComment[]

  @@index([organizationId, status])
  @@index([organizationId, status, createdAt(sort: Desc)]) // compound for filtered list
  @@index([organizationId, topic])
  @@index([organizationId, inventoryNumber])
  @@index([organizationId, categoryId])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, queueId])
  @@index([organizationId, teamId])
  @@index([assignedToId])
  @@index([contactId])
  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String
  content    String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@map("ticket_comments")
}

model ExchangeConfig {
  id             String    @id @default(cuid())
  organizationId String    @unique
  host           String
  port           Int       @default(993)
  username       String
  password       String
  mailbox        String    @default("INBOX")
  useSSL         Boolean   @default(true)
  enabled        Boolean   @default(false)
  lastCheckedAt  DateTime?
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("exchange_configs")
}

model LdapConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  host           String
  port           Int      @default(389)
  bindDn         String
  bindPassword   String
  baseDn         String
  loginBaseDn    String?
  userFilter     String   @default("(objectClass=person)")
  enabled        Boolean  @default(false)
  lastSyncAt     DateTime?
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("ldap_configs")
}

model TicketContact {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  company        String?
  department     String?
  externalId     String?
  source         String   @default("manual")
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets      Ticket[]
  portalUsers  PortalUser[]

  @@unique([organizationId, email])
  @@unique([organizationId, externalId])
  @@index([organizationId, source])
  @@index([organizationId, externalId])
  @@map("ticket_contacts")
}

model PortalUser {
  id             String   @id @default(cuid())
  organizationId String
  contactId      String?
  name           String
  email          String
  passwordHash   String?
  ldapUsername   String?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      TicketContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([organizationId, email])
  @@map("portal_users")
}

// ── Inventory ─────────────────────────────────────────────────────────────

enum AssetStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
  LOST
  RESERVED
}

model AssetCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  icon           String?
  position       Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets       Asset[]

  @@map("asset_categories")
}

model AssetLocation {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  building       String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets       Asset[]

  @@map("asset_locations")
}

model Asset {
  id              String      @id @default(cuid())
  organizationId  String
  categoryId      String?
  locationId      String?
  assignedToId    String?
  name            String
  inventoryNumber String?
  serialNumber    String?
  manufacturer    String?
  model           String?
  purchaseDate    DateTime?
  warrantyUntil   DateTime?
  purchasePrice   Decimal?    @db.Decimal(10, 2)
  status          AssetStatus @default(ACTIVE)
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       AssetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  location       AssetLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  assignedTo     User?          @relation("AssetAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignments    AssetAssignment[]
  softwareAgent  SoftwareAgent?

  @@index([organizationId, status])
  @@index([organizationId, categoryId])
  @@index([organizationId, assignedToId])
  @@index([inventoryNumber])
  @@map("assets")
}

model AssetAssignment {
  id         String    @id @default(cuid())
  assetId    String
  userId     String
  assignedAt DateTime  @default(now())
  returnedAt DateTime?
  notes      String?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user  User  @relation("AssetAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([userId])
  @@map("asset_assignments")
}

// ── Software Distribution ──────────────────────────────────────────────────

enum JobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

model SoftwarePackage {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?  @db.Text
  version        String?
  type           String   @default("winget")  // "winget" | "file" | "script"
  wingetId       String?
  fileName       String?
  fileData       String?  @db.Text  // base64, max ~25 MB
  fileMimeType   String?
  installParams  String?
  uninstallParams String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobs         SoftwareJob[]

  @@index([organizationId])
  @@map("software_packages")
}

model SoftwareAgent {
  id             String    @id @default(cuid())
  organizationId String
  hostname       String
  ipAddress      String?
  macAddress     String?
  osVersion      String?
  manufacturer   String?
  model          String?
  serialNumber   String?
  cpuName        String?
  cpuCores       Int?
  ramGb          Int?
  diskGb         Int?
  domain         String?
  assetId           String?   @unique // linked inventory asset (1:1)
  vlanId            String?   // auto-assigned from IP + VLAN definitions
  agentVersion      String?
  installedSoftware Json?
  apiKey            String    @unique @default(cuid())
  lastSeenAt     DateTime?
  createdAt      DateTime  @default(now())

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset         Asset?              @relation(fields: [assetId], references: [id], onDelete: SetNull)
  jobs          SoftwareJob[]
  groups        AgentGroupMember[]
  scanHistory   SoftwareScanHistory[]

  @@unique([organizationId, hostname])
  @@index([organizationId])
  @@map("software_agents")
}

model SoftwareJob {
  id          String    @id @default(cuid())
  packageId   String
  agentId     String
  jobType     String?   // overrides package.type if set (e.g. "file_copy")
  status      JobStatus @default(PENDING)
  exitCode    Int?
  log         String?   @db.Text
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  package SoftwarePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  agent   SoftwareAgent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, status])
  @@index([packageId])
  @@map("software_jobs")
}

// ── Password Reset ─────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ── Workspace Checklist ────────────────────────────────────────────────────

model WorkspaceChecklistCategory {
  id          String                   @id @default(cuid())
  name        String
  position    Int                      @default(0)
  workspaceId String
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  workspace Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items     WorkspaceChecklistItem[]

  @@map("workspace_checklist_categories")
}

model WorkspaceChecklistItem {
  id         String                @id @default(cuid())
  title      String
  priority   ChecklistItemPriority @default(MEDIUM)
  position   Int                   @default(0)
  categoryId String
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  category WorkspaceChecklistCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subItems WorkspaceChecklistSubItem[]

  @@map("workspace_checklist_items")
}

model WorkspaceChecklistSubItem {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  completed   Boolean  @default(false)
  position    Int      @default(0)
  itemId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  item WorkspaceChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("workspace_checklist_sub_items")
}

// ── Notes ─────────────────────────────────────────────────────────────────

enum NotePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model WorkspaceNote {
  id          String       @id @default(cuid())
  workspaceId String
  title       String       @default("Notiz")
  content     String?      @db.Text
  priority    NotePriority @default(MEDIUM)
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_notes")
}

model PersonalNote {
  id              String       @id @default(cuid())
  personalSpaceId String
  title           String       @default("Notiz")
  content         String?      @db.Text
  priority        NotePriority @default(MEDIUM)
  position        Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  personalSpace PersonalSpace @relation(fields: [personalSpaceId], references: [id], onDelete: Cascade)

  @@map("personal_notes")
}

// ── Personal Space ─────────────────────────────────────────────────────────

model PersonalSpace {
  id        String   @id @default(cuid())
  userId    String   @unique
  updatedAt DateTime @updatedAt

  user                        User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalChecklistCategories PersonalChecklistCategory[]
  personalNotes               PersonalNote[]

  @@map("personal_spaces")
}

model PersonalChecklistCategory {
  id              String                  @id @default(cuid())
  name            String
  position        Int                     @default(0)
  personalSpaceId String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  personalSpace PersonalSpace           @relation(fields: [personalSpaceId], references: [id], onDelete: Cascade)
  items         PersonalChecklistItem[]

  @@map("personal_checklist_categories")
}

model PersonalChecklistItem {
  id         String                @id @default(cuid())
  title      String
  priority   ChecklistItemPriority @default(MEDIUM)
  position   Int                   @default(0)
  categoryId String
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  category PersonalChecklistCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subItems PersonalChecklistSubItem[]

  @@map("personal_checklist_items")
}

model PersonalChecklistSubItem {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  completed   Boolean  @default(false)
  position    Int      @default(0)
  itemId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  item PersonalChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("personal_checklist_sub_items")
}

// ── Agent Groups ────────────────────────────────────────────────────────────

model AgentGroup {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      AgentGroupMember[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("agent_groups")
}

model AgentGroupMember {
  groupId String
  agentId String

  group AgentGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  agent SoftwareAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@id([groupId, agentId])
  @@map("agent_group_members")
}

// ── Network VLANs ───────────────────────────────────────────────────────────

model NetworkVlan {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  subnet         String   // CIDR notation e.g. "172.29.13.0/24"
  gateway        String?
  description    String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, subnet])
  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("network_vlans")
}

// ── Software Scan History ───────────────────────────────────────────────────

model SoftwareScanHistory {
  id        String   @id @default(cuid())
  agentId   String
  snapshot  Json     // installed software array at this point in time
  createdAt DateTime @default(now())

  agent SoftwareAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt(sort: Desc)])
  @@map("software_scan_history")
}
